# Groq LLM (required)
GROQ_API_KEY=gsk_your_groq_api_key_here

# LangSmith Observability (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_your_langsmith_key_here
LANGCHAIN_PROJECT=stock-portfolio-analyst

# WhatsApp Delivery (Twilio - optional for dev, required for prod)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# WhatsApp (Meta Business Cloud API - alternative to Twilio)
META_ACCESS_TOKEN=your_meta_access_token
META_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_TEMPLATE_ID=your_approved_template_id

# Database (for Postgres checkpointing - optional for dev)
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/stock_agent

# Agent Configuration
ALERT_COOLDOWN_HOURS=6
VAR_THRESHOLD_PCT=5.0
SECTOR_CONCENTRATION_LIMIT=40.0
SINGLE_STOCK_LIMIT=25.0
HIGH_SEVERITY_PRICE_MOVE_PCT=8.0

# Backtest Configuration
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-12-31
BENCHMARK_SYMBOL=NIFTY 50
